<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_qc_checksheet_template_form" model="ir.ui.view">
        <field name="name">qc.checksheet.template.form</field>
        <field name="model">qc.checksheet.template</field>
        <field name="arch" type="xml">
            <form string="QC Check Sheet Template">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Standard Company Template"/></h1>
                    </div>
                    <group>
                        <field name="checksheet_type" widget="radio" options="{'horizontal': true}"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                    <group string="Default Approval Positions">
                        <field name="default_approval_position_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="position"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_qc_checksheet_template_list" model="ir.ui.view">
        <field name="name">qc.checksheet.template.list</field>
        <field name="model">qc.checksheet.template</field>
        <field name="arch" type="xml">
            <list string="QC Check Sheet Templates">
                <field name="name"/>
                <field name="checksheet_type"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="action_qc_checksheet_template" model="ir.actions.act_window">
        <field name="name">Templates</field>
        <field name="res_model">qc.checksheet.template</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Check Sheet Template
            </p>
        </field>
    </record>

</odoo>
