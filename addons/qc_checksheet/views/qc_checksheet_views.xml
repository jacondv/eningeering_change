<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================= FORM VIEW ================= -->
    <record id="view_qc_checksheet_form" model="ir.ui.view">
        <field name="name">qc.checksheet.form</field>
        <field name="model">qc.checksheet</field>
        <field name="arch" type="xml">
            <form string="QC Check Sheet">
                <header>
                    <button string="Copy Content From..." name="%(action_qc_checksheet_copy_wizard)d"
                            type="action" context="{'default_checksheet_id': id}"
                            invisible="group_ids or panel_line_ids"/>
                    <button string="Import from Inventor BOM" name="%(action_qc_checksheet_inventor_import_wizard)d"
                            type="action" context="{'default_checksheet_id': id}"
                            invisible="checksheet_type != 'panel_sticker'"/>
                    <button string="Print PDF" name="%(action_report_qc_checksheet)d"
                            type="action" class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Start Up Check Sheet"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="reference"/>
                            <field name="header_title" placeholder="e.g. Panel &amp; Sticker Check Sheet"/>
                            <field name="checksheet_type" widget="radio" options="{'horizontal': true}"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="machine_serial"/>
                            <field name="machine_model"/>
                            <field name="engine_number"/>
                            <field name="check_date"/>
                            <field name="job_number"/>
                            <field name="customer"/>
                        </group>
                    </group>
                    <field name="copied_from_id" invisible="not copied_from_id" readonly="1"/>

                    <notebook>
                        <page string="Check Sheet Approval" name="approval">
                            <field name="approval_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="position"/>
                                </list>
                            </field>
                        </page>

                        <page string="Template History" name="history">
                            <field name="history_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="rev" readonly="1"/>
                                    <field name="description"/>
                                    <field name="date"/>
                                    <field name="created_by"/>
                                    <field name="approved_by"/>
                                    <field name="show_in_report" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>

                        <page string="Inspection Content" name="content"
                              invisible="checksheet_type != 'standard'">
                            <field name="group_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name" widget="html" options="{'style-inline': true}"/>
                                    <field name="item_count" string="Items"/>
                                </list>
                                <form string="Inspection Group">
                                    <group>
                                        <field name="name" widget="html" options="{'style-inline': true}"/>
                                    </group>
                                    <field name="item_ids">
                                        <list editable="bottom">
                                            <field name="sequence" widget="handle"/>
                                            <field name="item_number" string="Item" readonly="1"/>
                                            <field name="description" widget="html" options="{'style-inline': true}"/>
                                            <field name="acceptance" widget="html" options="{'style-inline': true}"/>
                                            <field name="note"/>
                                        </list>
                                    </field>
                                </form>
                            </field>
                        </page>

                        <page string="Images" name="images"
                              invisible="checksheet_type != 'panel_sticker'">
                            <field name="image_group_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                </list>
                                <form string="Image Group" class="o_qc_image_line_dialog">
                                    <group>
                                        <field name="name"/>
                                    </group>
                                    <field name="image_line_ids">
                                        <list editable="bottom">
                                            <field name="sequence" widget="handle"/>
                                            <field name="image" widget="image" options="{'size': [96, 96]}" width="110px"/>
                                            <field name="description"/>
                                            <field name="size_percent" string="Height %" width="70px"/>
                                            <field name="width_percent" string="Width %" width="70px"/>
                                            <field name="keep_original_size" string="Actual Size" width="80px"/>
                                            <field name="page_break_after" string="Break After" width="80px"/>
                                        </list>
                                    </field>
                                </form>
                            </field>
                        </page>

                        <page string="Panel &amp; Sticker" name="panel_lines"
                              invisible="checksheet_type != 'panel_sticker'">
                            <field name="panel_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="item_number"/>
                                    <field name="part_number"/>
                                    <field name="description"/>
                                    <field name="image" widget="image" options="{'size': [64, 64]}"/>
                                    <field name="qty"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>

                        <page string="Remarks" name="remarks">
                            <field name="remarks"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================= LIST VIEW ================= -->
    <record id="view_qc_checksheet_list" model="ir.ui.view">
        <field name="name">qc.checksheet.list</field>
        <field name="model">qc.checksheet</field>
        <field name="arch" type="xml">
            <list string="QC Check Sheets">
                <field name="reference"/>
                <field name="name"/>
                <field name="checksheet_type"/>
                <field name="machine_serial"/>
                <field name="job_number"/>
                <field name="check_date"/>
            </list>
        </field>
    </record>

    <!-- ================= SEARCH VIEW ================= -->
    <record id="view_qc_checksheet_search" model="ir.ui.view">
        <field name="name">qc.checksheet.search</field>
        <field name="model">qc.checksheet</field>
        <field name="arch" type="xml">
            <search string="Search Check Sheets">
                <field name="name"/>
                <field name="reference"/>
                <field name="machine_serial"/>
                <field name="job_number"/>
                <filter string="Standard" name="type_standard" domain="[('checksheet_type', '=', 'standard')]"/>
                <filter string="Panel &amp; Sticker" name="type_panel" domain="[('checksheet_type', '=', 'panel_sticker')]"/>
                <group>
                    <filter string="Type" name="group_type" context="{'group_by': 'checksheet_type'}"/>
                    <filter string="Job Number" name="group_job" context="{'group_by': 'job_number'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================= ACTIONS ================= -->
    <record id="action_qc_checksheet_all" model="ir.actions.act_window">
        <field name="name">Check Sheets</field>
        <field name="res_model">qc.checksheet</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_qc_checksheet_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Check Sheet
            </p>
        </field>
    </record>

</odoo>
