<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_qc_checksheet_import_wizard_form" model="ir.ui.view">
        <field name="name">qc.checksheet.import.wizard.form</field>
        <field name="model">qc.checksheet.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Panel Lines">
                <group>
                    <field name="checksheet_id" invisible="1"/>
                    <field name="import_file" filename="import_filename"/>
                    <field name="import_filename" invisible="1"/>
                    <field name="replace_existing"/>
                </group>
                <group string="Column Mapping">
                    <field name="part_number_column"/>
                    <field name="qty_column"/>
                    <field name="note_column"/>
                </group>
                <footer>
                    <button string="Import" name="action_import" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_qc_checksheet_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Panel Lines</field>
        <field name="res_model">qc.checksheet.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
