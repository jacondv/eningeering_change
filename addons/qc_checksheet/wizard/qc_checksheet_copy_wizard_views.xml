<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_qc_checksheet_copy_wizard_form" model="ir.ui.view">
        <field name="name">qc.checksheet.copy.wizard.form</field>
        <field name="model">qc.checksheet.copy.wizard</field>
        <field name="arch" type="xml">
            <form string="Copy Check Sheet Content">
                <field name="checksheet_id" invisible="1"/>
                <field name="checksheet_type" invisible="1"/>
                <group>
                    <field name="source_checksheet_id"/>
                </group>
                <footer>
                    <button string="Copy" name="action_copy" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_qc_checksheet_copy_wizard" model="ir.actions.act_window">
        <field name="name">Copy Content From</field>
        <field name="res_model">qc.checksheet.copy.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
