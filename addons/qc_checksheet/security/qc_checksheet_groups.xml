<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="module_category_qc_checksheet" model="ir.module.category">
            <field name="name">QC Check Sheet</field>
            <field name="sequence">30</field>
        </record>

        <!-- Single privilege on purpose (see techspec §7, decision 5): no separate
             "Manager" group. Granular access (who may touch what) is left to
             Odoo's standard per-user Settings rather than modeled as more groups. -->
        <record id="privilege_qc_checksheet_user" model="res.groups.privilege">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_qc_checksheet"/>
            <field name="sequence">10</field>
        </record>

        <record id="group_qc_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="privilege_qc_checksheet_user"/>
            <field name="comment">Can create, edit and print QC Check Sheets and Templates.</field>
        </record>

    </data>
</odoo>
