<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="seq_engineering_change" model="ir.sequence">
        <field name="name">Engineering Change Request No</field>
        <field name="code">engineering.change</field>
        <field name="prefix">%(y)s%(month)s-</field>
        <field name="padding">3</field>
        <field name="number_increment">1</field>
        <field name="use_date_range">True</field>
        <field name="implementation">standard</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_engineering_change_dcr" model="ir.sequence">
        <field name="name">Engineering Change DCR No</field>
        <field name="code">engineering.change.dcr</field>
        <field name="prefix">%(year)sDC</field>
        <field name="padding">3</field>
        <field name="number_increment">1</field>
        <field name="use_date_range">True</field>
        <field name="implementation">standard</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>
