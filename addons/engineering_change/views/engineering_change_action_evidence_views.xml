<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Standalone list/form for engineering.change.action.evidence, used by
         the Request form's "Evidence" smart button so it can jump straight to
         evidence records (across every task of the request) instead of the
         task list. task_id is a real Many2one here (unlike the inline list
         embedded in the task form), so it renders with Odoo's standard
         internal-link arrow to open the originating task. -->

    <!-- ================= FORM VIEW ================= -->
    <record id="view_engineering_change_action_evidence_form" model="ir.ui.view">
        <field name="name">engineering.change.action.evidence.form</field>
        <field name="model">engineering.change.action.evidence</field>
        <field name="arch" type="xml">
            <form string="Evidence">
                <sheet>
                    <group>
                        <group>
                            <field name="task_id"/>
                            <field name="description"/>
                        </group>
                        <group>
                            <field name="upload_uid" readonly="1"/>
                            <field name="upload_date" readonly="1"/>
                        </group>
                    </group>
                    <field name="attachment" filename="attachment_filename"/>
                    <field name="attachment_filename" invisible="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================= LIST VIEW ================= -->
    <record id="view_engineering_change_action_evidence_list" model="ir.ui.view">
        <field name="name">engineering.change.action.evidence.list</field>
        <field name="model">engineering.change.action.evidence</field>
        <field name="arch" type="xml">
            <list string="Evidence">
                <button name="action_open_attachment" type="object"
                        icon="fa-external-link" title="Open File"
                        invisible="not attachment"/>
                <field name="task_id"/>
                <field name="description"/>
                <field name="attachment" filename="attachment_filename"/>
                <field name="attachment_filename" column_invisible="1"/>
                <field name="upload_uid"/>
                <field name="upload_date"/>
            </list>
        </field>
    </record>

</odoo>
