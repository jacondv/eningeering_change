<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Engineering Change actions/tasks are project.task records (change_id set).
         These views are lightweight, EC-focused alternatives to the full Project
         app views, reused wherever an EC task needs to be listed/edited. -->

    <!-- ================= FORM VIEW ================= -->
    <!-- Inherits Project's own task form (project.view_task_form2) so an
         Engineering Change action/task shows every standard Odoo task field
         (assignees, deadline, tags, sub-tasks, dependencies...) instead of a
         stripped-down substitute, plus the EC-specific bits (Engineering
         Change No / Manager / Evidence tab). Core fields that aren't in
         ASSIGNEE_EDITABLE_FIELDS are made readonly unless the current user
         is the Manager or the request's Implement Owner, mirroring the
         write guard in _check_ec_write_access - otherwise a plain assignee
         could edit them in the UI only to have the whole save rejected. -->
    <record id="view_engineering_change_action_form" model="ir.ui.view">
        <field name="name">project.task.ec.form</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <field name="is_template" position="after">
                <field name="can_edit_ec_task_details" invisible="1"/>
            </field>

            <field name="task_properties" position="before">
                <group string="Engineering Change" invisible="not change_id">
                    <field name="change_id" readonly="1"/>
                    <field name="manager_id" readonly="change_id and not can_edit_ec_task_details"/>
                    <field name="affected_project_ids" widget="many2many_tags"/>
                </group>
            </field>

            <!-- Fields not in ASSIGNEE_EDITABLE_FIELDS: readonly for anyone
                 but the Manager / Implement Owner once an EC task. Targets
                 the outer two-column <group> wrapping project_id/milestone_id/
                 user_ids/role_ids and tag_ids/partner_id/date_deadline/
                 recurring_task - readonly cascades down to every field in
                 both sub-groups. -->
            <xpath expr="//field[@name='project_id']/ancestor::group[2]" position="attributes">
                <attribute name="readonly">change_id and not can_edit_ec_task_details</attribute>
            </xpath>
            <field name="task_properties" position="attributes">
                <attribute name="readonly">change_id and not can_edit_ec_task_details</attribute>
            </field>
            <xpath expr="//page[@name='description_page']/field[@name='description']" position="attributes">
                <attribute name="readonly">change_id and not can_edit_ec_task_details</attribute>
            </xpath>

            <page name="description_page" position="after">
                <page string="Evidence" name="evidence" invisible="not change_id">
                    <field name="evidence_ids">
                        <list editable="bottom">
                            <button name="action_open_attachment" type="object"
                                    icon="fa-external-link" title="Open File"
                                    invisible="not attachment"/>
                            <field name="attachment" filename="attachment_filename"/>
                            <field name="attachment_filename" column_invisible="1"/>
                            <field name="description"/>
                            <field name="upload_uid" readonly="1"/>
                            <field name="upload_date" readonly="1"/>
                        </list>
                    </field>
                </page>
            </page>
        </field>
    </record>

    <!-- ================= LIST VIEW ================= -->
    <record id="view_engineering_change_action_list" model="ir.ui.view">
        <field name="name">project.task.ec.list</field>
        <field name="model">project.task</field>
        <field name="arch" type="xml">
            <list string="Engineering Change Actions" decoration-danger="is_overdue">
                <field name="change_id"/>
                <field name="name"/>
                <field name="user_ids" widget="many2many_tags"/>
                <field name="manager_id"/>
                <field name="affected_project_ids" widget="many2many_tags" optional="show"/>
                <field name="date_deadline"/>
                <field name="state" widget="badge"
                       decoration-success="state == '1_done'"
                       decoration-info="state == '01_in_progress'"
                       decoration-muted="state == '1_canceled'"/>
                <field name="is_overdue" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ================= SEARCH VIEW ================= -->
    <record id="view_engineering_change_action_search" model="ir.ui.view">
        <field name="name">project.task.ec.search</field>
        <field name="model">project.task</field>
        <field name="arch" type="xml">
            <search string="Search Actions">
                <field name="name"/>
                <field name="change_id"/>
                <field name="user_ids"/>
                <field name="affected_project_ids"/>
                <filter string="My Tasks" name="my_tasks" domain="[('user_ids', 'in', [uid])]"/>
                <filter string="Overdue" name="overdue" domain="[('is_overdue', '=', True)]"/>
                <separator/>
                <filter string="In Progress" name="status_in_progress" domain="[('state', '=', '01_in_progress')]"/>
                <filter string="Changes Requested" name="status_changes_requested" domain="[('state', '=', '02_changes_requested')]"/>
                <filter string="Approved" name="status_approved" domain="[('state', '=', '03_approved')]"/>
                <filter string="Done" name="status_done" domain="[('state', '=', '1_done')]"/>
                <filter string="Cancelled" name="status_cancel" domain="[('state', '=', '1_canceled')]"/>
                <filter string="Waiting" name="status_waiting" domain="[('state', '=', '04_waiting_normal')]"/>
                <group>
                    <filter string="Status" name="group_status" context="{'group_by': 'state'}"/>
                    <filter string="Assignee" name="group_assignee" context="{'group_by': 'user_ids'}"/>
                    <filter string="Request" name="group_change" context="{'group_by': 'change_id'}"/>
                    <filter string="Impacted Project" name="group_affected_project" context="{'group_by': 'affected_project_ids'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================= ACTION ================= -->
    <record id="action_engineering_change_action" model="ir.actions.act_window">
        <field name="name">Actions / Tasks</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('change_id', '!=', False), ('change_id.active', '=', True)]</field>
        <field name="search_view_id" ref="view_engineering_change_action_search"/>
        <field name="context">{'search_default_my_tasks': 1, 'search_default_group_status': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No action/task found
            </p>
        </field>
    </record>

    <record id="action_engineering_change_action_list_view" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_engineering_change_action_list"/>
        <field name="act_window_id" ref="action_engineering_change_action"/>
    </record>

    <record id="action_engineering_change_action_form_view" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_engineering_change_action_form"/>
        <field name="act_window_id" ref="action_engineering_change_action"/>
    </record>

</odoo>
